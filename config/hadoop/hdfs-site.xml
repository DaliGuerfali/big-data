<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>

  <!-- Replication factor (1 for single-node dev cluster) -->
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>

  <!-- NameNode data directory -->
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>file:///hadoop/dfs/name</value>
  </property>

  <!-- DataNode data directory -->
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:///hadoop/dfs/data</value>
  </property>

  <!-- Block size (128MB) -->
  <property>
    <name>dfs.blocksize</name>
    <value>134217728</value>
  </property>

  <!-- Web UI bind address -->
  <property>
    <name>dfs.namenode.http-address</name>
    <value>namenode:9870</value>
  </property>

  <!-- DataNode web UI -->
  <property>
    <name>dfs.datanode.http.address</name>
    <value>0.0.0.0:9864</value>
  </property>

  <!-- Allow writing in safe mode (dev only) -->
  <property>
    <name>dfs.safemode.threshold.pct</name>
    <value>0</value>
  </property>

  <!-- Short-circuit reads for Spark performance -->
  <property>
    <name>dfs.client.read.shortcircuit</name>
    <value>false</value>
  </property>

  <!-- Permissions (relaxed for dev) -->
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>

</configuration>
