# ─────────────────────────────────────────────────────────
# Satellite Tracker — Environment Configuration Example
#
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in the values marked with <...>
#   3. Never commit .env to version control
# ─────────────────────────────────────────────────────────

# ── API Keys ─────────────────────────────────────────────

# N2YO Satellite Tracker
#   1. Register at https://www.n2yo.com/register/
#   2. Log in → go to your profile page
#   3. Generate your REST API key (different from SOAP key)
#   Rate limit: 1000 req/hour for positions and TLE endpoints
N2YO_API_KEY=<your_n2yo_api_key>

# NASA APIs (used for DONKI space weather events)
#   Option A — use DEMO_KEY (free, no signup):
#     - 30 requests/hour, 50 requests/day
#     - Fine for development and demos
#   Option B — get a free personal key (recommended):
#     - Register at https://api.nasa.gov/
#     - 1000 requests/hour
#   Leave as DEMO_KEY if you just want to test quickly.
NASA_API_KEY=DEMO_KEY

# ── Kafka ─────────────────────────────────────────────────
# Internal address used by producers/consumers inside Docker network
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# External address used when running producers on the host machine
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:29092

# ── HDFS ──────────────────────────────────────────────────
HDFS_NAMENODE_URL=hdfs://namenode:8020

# ── Spark ─────────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Airflow ───────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ── Grafana ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Producer Polling Intervals (seconds) ─────────────────
# ISS: Open-Notify has no rate limit — 5s is safe
ISS_POLL_INTERVAL_SECONDS=5

# N2YO: 1000 req/hour limit → 15s for 3 satellites = ~720 req/hour
N2YO_POLL_INTERVAL_SECONDS=15

# DONKI: No stated limit, but events update infrequently — 5 min is enough
DONKI_POLL_INTERVAL_SECONDS=300

# TLE API: Data is updated daily — fetch hourly is more than enough
TLE_FETCH_INTERVAL_SECONDS=3600

# ── Observer Location (for N2YO pass predictions) ────────
# Set to your actual location for accurate pass predictions
# Default below is Tunis, Tunisia
OBSERVER_LATITUDE=36.8
OBSERVER_LONGITUDE=10.18
OBSERVER_ALTITUDE=0

# ── Satellites to Track (NORAD IDs, comma-separated) ─────
# 25544 = ISS
# 20580 = Hubble Space Telescope
# 43013 = Starlink-24 (example)
# Find more NORAD IDs at: https://www.n2yo.com or https://celestrak.org
TRACKED_SATELLITES=25544,20580,43013
